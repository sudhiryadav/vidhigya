generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Practice {
  id                 String              @id @default(cuid())
  name               String
  practiceType       PracticeType        @default(INDIVIDUAL)
  description        String?
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  billing            BillingRecord[]
  events             CalendarEvent[]
  callParticipants   CallParticipant[]
  caseNotes          CaseNote[]
  chatMessages       ChatMessage[]
  clientPortals      ClientPortal[]
  clients            Client[]
  documentQueries    DocumentQuery[]
  documentSignatures DocumentSignature[]
  eventParticipants  EventParticipant[]
  feedback           Feedback[]
  fileShares         FileShare[]
  firm               Firm?
  cases              LegalCase[]
  documents          LegalDocument[]
  notifications      Notification[]
  members            PracticeMember[]
  tasks              Task[]
  timeEntries        TimeEntry[]
  userSettings       UserSettings[]
  videoCalls         VideoCall[]
  primaryForUsers    User[]              @relation("UserPrimaryPractice")

  @@map("practices")
}

model Firm {
  id                 String       @id @default(cuid())
  practiceId         String       @unique
  registrationNumber String?
  address            String?
  city               String?
  state              String?
  country            String       @default("India")
  pincode            String?
  phone              String?
  email              String?
  website            String?
  taxId              String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  departments        Department[]
  practice           Practice     @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  @@map("firms")
}

model Department {
  id           String           @id @default(cuid())
  firmId       String
  name         String
  description  String?
  practiceArea String?
  isActive     Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  firm         Firm             @relation(fields: [firmId], references: [id], onDelete: Cascade)
  members      PracticeMember[]

  @@map("departments")
}

model PracticeMember {
  id           String   @id @default(cuid())
  practiceId   String
  userId       String
  departmentId String?
  supervisorId String?
  permissions  Json?
  isActive     Boolean  @default(true)
  joinDate     DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  department   Department?      @relation(fields: [departmentId], references: [id])
  practice     Practice         @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  supervisor   PracticeMember?  @relation("StaffSupervision", fields: [supervisorId], references: [id])
  supervised   PracticeMember[] @relation("StaffSupervision")
  user         User             @relation("UserPractices", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([practiceId, userId])
  @@map("practice_members")
}

model Client {
  id              String          @id @default(cuid())
  practiceId      String
  name            String
  email           String?
  phone           String?
  address         String?
  userId          String?
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  billing         BillingRecord[] @relation("ClientBilling")
  events          CalendarEvent[] @relation("ClientEvents")
  practice        Practice        @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  documentQueries DocumentQuery[] @relation("ClientDocumentQueries")
  fileShares      FileShare[]     @relation("ClientFileShares")
  documents       LegalDocument[] @relation("ClientDocuments")
  tasks           Task[]          @relation("ClientTasks")
  timeEntries     TimeEntry[]     @relation("ClientTimeEntries")
  user            User?           @relation("ClientUser")
  videoCalls      VideoCall[]     @relation("ClientVideoCalls")
  cases           LegalCase[]

  @@map("clients")
}

model Log {
  id        String   @id @default(cuid())
  level     String
  message   String
  meta      Json?
  userId    String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@map("logs")
}

model User {
  id                   String              @id @default(cuid())
  email                String              @unique
  name                 String
  password             String
  role                 UserRole            @default(CLIENT)
  phone                String?
  isActive             Boolean             @default(true)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  address              String?
  emailVerified        Boolean             @default(false)
  avatarS3Key          String?
  clientId             String?             @unique
  primaryPracticeId    String?
  billingRecords       BillingRecord[]
  createdEvents        CalendarEvent[]     @relation("EventCreator")
  callParticipants     CallParticipant[]
  caseNotes            CaseNote[]
  chatMessagesReceived ChatMessage[]       @relation("MessageReceiver")
  chatMessagesSent     ChatMessage[]       @relation("MessageSender")
  clientPortal         ClientPortal?
  documentQueries      DocumentQuery[]
  documentSignatures   DocumentSignature[]
  eventParticipants    EventParticipant[]
  feedback             Feedback[]
  fileShares           FileShare[]         @relation("FileOwner")
  sharedFiles          FileShare[]         @relation("FileSharedWith")
  assignedCases        LegalCase[]         @relation("AssignedLawyer")
  uploadedDocuments    LegalDocument[]
  logs                 Log[]
  notifications        Notification[]
  practices            PracticeMember[]    @relation("UserPractices")
  assignedTasks        Task[]              @relation("TaskAssignee")
  createdTasks         Task[]              @relation("TaskCreator")
  timeEntries          TimeEntry[]
  userSettings         UserSettings?
  client               Client?             @relation("ClientUser", fields: [clientId], references: [id])
  primaryPractice      Practice?           @relation("UserPrimaryPractice", fields: [primaryPracticeId], references: [id])
  videoCalls           VideoCall[]         @relation("CallHost")

  @@map("users")
}

model Court {
  id           String      @id @default(cuid())
  name         String      @unique
  type         CourtType
  address      String
  city         String
  state        String
  country      String      @default("India")
  pincode      String?
  phone        String?
  email        String?
  website      String?
  jurisdiction String?
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  cases        LegalCase[]

  @@map("courts")
}

model LegalCase {
  id                      String          @id @default(cuid())
  caseNumber              String          @unique
  title                   String
  description             String
  status                  CaseStatus      @default(OPEN)
  priority                CasePriority    @default(MEDIUM)
  category                CaseCategory
  judge                   String?
  opposingParty           String?
  opposingLawyer          String?
  filingDate              DateTime?
  nextHearingDate         DateTime?
  estimatedCompletionDate DateTime?
  assignedLawyerId        String
  clientId                String
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt
  courtId                 String?
  practiceId              String
  billingRecords          BillingRecord[]
  events                  CalendarEvent[]
  notes                   CaseNote[]
  documentQueries         DocumentQuery[]
  fileShares              FileShare[]
  assignedLawyer          User            @relation("AssignedLawyer", fields: [assignedLawyerId], references: [id])
  client                  Client          @relation(fields: [clientId], references: [id])
  court                   Court?          @relation(fields: [courtId], references: [id])
  practice                Practice        @relation(fields: [practiceId], references: [id])
  documents               LegalDocument[]
  tasks                   Task[]
  timeEntries             TimeEntry[]
  videoCalls              VideoCall[]

  @@map("legal_cases")
}

model LegalDocument {
  id               String              @id @default(cuid())
  title            String
  description      String?
  fileType         String
  fileSize         Int
  category         DocumentCategory
  status           DocumentStatus      @default(DRAFT)
  caseId           String?
  uploadedById     String
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  fileUrl          String
  aiChunks         Int?
  aiDocumentId     String?
  content          String?
  originalFilename String?
  clientId         String?
  practiceId       String
  signatures       DocumentSignature[]
  fileShares       FileShare[]
  case             LegalCase?          @relation(fields: [caseId], references: [id])
  client           Client?             @relation("ClientDocuments", fields: [clientId], references: [id])
  practice         Practice            @relation(fields: [practiceId], references: [id])
  uploadedBy       User                @relation(fields: [uploadedById], references: [id])

  @@map("legal_documents")
}

model CaseNote {
  id         String    @id @default(cuid())
  content    String
  type       NoteType  @default(GENERAL)
  caseId     String
  userId     String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  practiceId String
  case       LegalCase @relation(fields: [caseId], references: [id])
  practice   Practice  @relation(fields: [practiceId], references: [id])
  user       User      @relation(fields: [userId], references: [id])

  @@map("case_notes")
}

model ChatMessage {
  id          String      @id @default(cuid())
  content     String
  messageType MessageType @default(TEXT)
  senderId    String
  receiverId  String
  isRead      Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  practiceId  String
  practice    Practice    @relation(fields: [practiceId], references: [id])
  receiver    User        @relation("MessageReceiver", fields: [receiverId], references: [id])
  sender      User        @relation("MessageSender", fields: [senderId], references: [id])

  @@map("chat_messages")
}

model BillingRecord {
  id          String     @id @default(cuid())
  amount      Float
  description String
  billType    BillType
  status      BillStatus @default(PENDING)
  dueDate     DateTime?
  paidDate    DateTime?
  caseId      String?
  userId      String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  currency    Currency   @default(INR)
  clientId    String?
  practiceId  String
  case        LegalCase? @relation(fields: [caseId], references: [id])
  client      Client?    @relation("ClientBilling", fields: [clientId], references: [id])
  practice    Practice   @relation(fields: [practiceId], references: [id])
  user        User       @relation(fields: [userId], references: [id])

  @@map("billing_records")
}

model Notification {
  id         String           @id @default(cuid())
  title      String
  message    String
  type       NotificationType
  isRead     Boolean          @default(false)
  userId     String
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  practiceId String
  practice   Practice         @relation(fields: [practiceId], references: [id])
  user       User             @relation(fields: [userId], references: [id])

  @@map("notifications")
}

model CalendarEvent {
  id             String             @id @default(cuid())
  title          String
  description    String?
  startTime      DateTime
  endTime        DateTime
  location       String?
  eventType      EventType
  isAllDay       Boolean            @default(false)
  isRecurring    Boolean            @default(false)
  recurrenceRule String?
  caseId         String?
  createdById    String
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  clientId       String?
  practiceId     String
  case           LegalCase?         @relation(fields: [caseId], references: [id])
  client         Client?            @relation("ClientEvents", fields: [clientId], references: [id])
  createdBy      User               @relation("EventCreator", fields: [createdById], references: [id])
  practice       Practice           @relation(fields: [practiceId], references: [id])
  participants   EventParticipant[]

  @@map("calendar_events")
}

model EventParticipant {
  id         String            @id @default(cuid())
  eventId    String
  userId     String
  status     ParticipantStatus @default(PENDING)
  response   String?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  practiceId String
  event      CalendarEvent     @relation(fields: [eventId], references: [id])
  practice   Practice          @relation(fields: [practiceId], references: [id])
  user       User              @relation(fields: [userId], references: [id])

  @@unique([eventId, userId])
  @@map("event_participants")
}

model VideoCall {
  id           String            @id @default(cuid())
  title        String
  description  String?
  startTime    DateTime
  endTime      DateTime?
  meetingUrl   String
  meetingId    String            @unique
  status       CallStatus        @default(SCHEDULED)
  caseId       String?
  hostId       String
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  clientId     String?
  practiceId   String
  participants CallParticipant[]
  case         LegalCase?        @relation(fields: [caseId], references: [id])
  client       Client?           @relation("ClientVideoCalls", fields: [clientId], references: [id])
  host         User              @relation("CallHost", fields: [hostId], references: [id])
  practice     Practice          @relation(fields: [practiceId], references: [id])

  @@map("video_calls")
}

model CallParticipant {
  id         String    @id @default(cuid())
  callId     String
  userId     String
  joinedAt   DateTime?
  leftAt     DateTime?
  duration   Int?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  practiceId String
  call       VideoCall @relation(fields: [callId], references: [id])
  practice   Practice  @relation(fields: [practiceId], references: [id])
  user       User      @relation(fields: [userId], references: [id])

  @@unique([callId, userId])
  @@map("call_participants")
}

model TimeEntry {
  id          String     @id @default(cuid())
  description String
  startTime   DateTime
  endTime     DateTime?
  duration    Int?
  billable    Boolean    @default(true)
  rate        Float?
  caseId      String?
  userId      String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  clientId    String?
  practiceId  String
  case        LegalCase? @relation(fields: [caseId], references: [id])
  client      Client?    @relation("ClientTimeEntries", fields: [clientId], references: [id])
  practice    Practice   @relation(fields: [practiceId], references: [id])
  user        User       @relation(fields: [userId], references: [id])

  @@map("time_entries")
}

model Task {
  id           String       @id @default(cuid())
  title        String
  description  String?
  status       TaskStatus   @default(PENDING)
  priority     TaskPriority @default(MEDIUM)
  dueDate      DateTime?
  completedAt  DateTime?
  caseId       String?
  createdById  String
  assignedToId String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  clientId     String?
  practiceId   String
  assignedTo   User?        @relation("TaskAssignee", fields: [assignedToId], references: [id])
  case         LegalCase?   @relation(fields: [caseId], references: [id])
  client       Client?      @relation("ClientTasks", fields: [clientId], references: [id])
  createdBy    User         @relation("TaskCreator", fields: [createdById], references: [id])
  practice     Practice     @relation(fields: [practiceId], references: [id])

  @@map("tasks")
}

model ClientPortal {
  id          String    @id @default(cuid())
  isActive    Boolean   @default(true)
  lastLoginAt DateTime?
  preferences Json?
  userId      String    @unique
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  practiceId  String
  practice    Practice  @relation(fields: [practiceId], references: [id])
  user        User      @relation(fields: [userId], references: [id])

  @@map("client_portals")
}

model DocumentSignature {
  id         String        @id @default(cuid())
  signature  String
  signedAt   DateTime
  ipAddress  String?
  userAgent  String?
  documentId String
  userId     String
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  practiceId String
  document   LegalDocument @relation(fields: [documentId], references: [id])
  practice   Practice      @relation(fields: [practiceId], references: [id])
  user       User          @relation(fields: [userId], references: [id])

  @@map("document_signatures")
}

model FileShare {
  id           String         @id @default(cuid())
  fileName     String
  fileType     String
  fileSize     Int
  expiresAt    DateTime?
  isPublic     Boolean        @default(false)
  caseId       String?
  documentId   String?
  ownerId      String
  sharedWithId String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  fileUrl      String
  clientId     String?
  practiceId   String
  case         LegalCase?     @relation(fields: [caseId], references: [id])
  client       Client?        @relation("ClientFileShares", fields: [clientId], references: [id])
  document     LegalDocument? @relation(fields: [documentId], references: [id])
  owner        User           @relation("FileOwner", fields: [ownerId], references: [id])
  practice     Practice       @relation(fields: [practiceId], references: [id])
  sharedWith   User?          @relation("FileSharedWith", fields: [sharedWithId], references: [id])

  @@map("file_shares")
}

model UserSettings {
  id                  String   @id @default(cuid())
  userId              String   @unique
  currency            Currency @default(INR)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  analyticsEnabled    Boolean  @default(true)
  auditLogging        Boolean  @default(true)
  autoBackup          Boolean  @default(true)
  backupNotifications Boolean  @default(true)
  billingAlerts       Boolean  @default(true)
  calendarReminders   Boolean  @default(true)
  caseUpdates         Boolean  @default(true)
  dataRetention       String   @default("90")
  dataSharing         Boolean  @default(true)
  dateFormat          String   @default("MM/DD/YYYY")
  debugMode           Boolean  @default(false)
  emailNotifications  Boolean  @default(true)
  emailProvider       String   @default("smtp")
  ipWhitelist         String   @default("")
  language            String   @default("en")
  maintenanceMode     Boolean  @default(false)
  passwordPolicy      String   @default("strong")
  profileVisibility   String   @default("public")
  pushNotifications   Boolean  @default(true)
  securityEvents      Boolean  @default(true)
  sessionTimeout      String   @default("30")
  smsNotifications    Boolean  @default(false)
  smsProvider         String   @default("twilio")
  storageProvider     String   @default("local")
  systemAlerts        Boolean  @default(true)
  theme               String   @default("system")
  timezone            String   @default("UTC")
  twoFactorAuth       Boolean  @default(false)
  userActivity        Boolean  @default(false)
  fontSize            String   @default("sm")
  practiceId          String
  practice            Practice @relation(fields: [practiceId], references: [id])
  user                User     @relation(fields: [userId], references: [id])

  @@map("user_settings")
}

model Feedback {
  id         String       @id @default(cuid())
  userId     String
  messageId  String
  feedback   FeedbackType
  question   String
  answer     String
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  practiceId String
  practice   Practice     @relation(fields: [practiceId], references: [id])
  user       User         @relation(fields: [userId], references: [id])

  @@map("feedback")
}

model DocumentQuery {
  id           String     @id @default(cuid())
  userId       String
  caseId       String?
  question     String
  answer       String
  sources      Json?
  queryType    QueryType  @default(GENERAL)
  responseTime Int?
  tokensUsed   Int?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?
  isDeleted    Boolean    @default(false)
  clientId     String?
  practiceId   String
  case         LegalCase? @relation(fields: [caseId], references: [id])
  client       Client?    @relation("ClientDocumentQueries", fields: [clientId], references: [id])
  practice     Practice   @relation(fields: [practiceId], references: [id])
  user         User       @relation(fields: [userId], references: [id])

  @@map("document_queries")
}

enum PracticeType {
  INDIVIDUAL
  FIRM
  MIXED
}



enum UserRole {
  LAWYER
  CLIENT
  ADMIN
  ASSOCIATE
  PARALEGAL
  SUPER_ADMIN
}

enum CaseStatus {
  OPEN
  IN_PROGRESS
  PENDING
  CLOSED
  ARCHIVED
}

enum CasePriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum CaseCategory {
  CIVIL
  CRIMINAL
  FAMILY
  CORPORATE
  PROPERTY
  LABOR
  TAX
  INTELLECTUAL_PROPERTY
  OTHER
}

enum DocumentCategory {
  CONTRACT
  AGREEMENT
  PETITION
  AFFIDAVIT
  EVIDENCE
  COURT_ORDER
  LEGAL_OPINION
  OTHER
}

enum DocumentStatus {
  DRAFT
  REVIEW
  APPROVED
  FILED
  ARCHIVED
  PROCESSING
  PROCESSED
}

enum NoteType {
  GENERAL
  HEARING
  EVIDENCE
  STRATEGY
  REMINDER
}

enum MessageType {
  TEXT
  FILE
  IMAGE
  AUDIO
}

enum BillType {
  CONSULTATION
  COURT_APPEARANCE
  DOCUMENT_PREPARATION
  RESEARCH
  OTHER
}

enum BillStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum NotificationType {
  CASE_UPDATE
  DOCUMENT_UPLOAD
  HEARING_REMINDER
  BILLING
  MESSAGE
  SYSTEM
}

enum EventType {
  HEARING
  CLIENT_MEETING
  COURT_APPEARANCE
  DEADLINE
  INTERNAL_MEETING
  OTHER
}

enum ParticipantStatus {
  PENDING
  ACCEPTED
  DECLINED
  TENTATIVE
}

enum CallStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum Currency {
  INR
  USD
  EUR
  GBP
  JPY
  AUD
  CAD
  CHF
  CNY
  HKD
  NZD
  SEK
  SGD
  THB
  TRY
  ZAR
}

enum CourtType {
  SUPREME_COURT
  HIGH_COURT
  DISTRICT_COURT
  SESSIONS_COURT
  MAGISTRATE_COURT
  FAMILY_COURT
  LABOR_COURT
  CONSUMER_COURT
  TRIBUNAL
  SPECIAL_COURT
  OTHER
}

enum FeedbackType {
  POSITIVE
  NEGATIVE
}

enum QueryType {
  GENERAL
  CASE_SPECIFIC
  DOCUMENT_ANALYSIS
  LEGAL_RESEARCH
  DRAFT_GENERATION
  SUMMARY_REQUEST
}
