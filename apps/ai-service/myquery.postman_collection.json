{
    "info": {
        "name": "MyQuery API",
        "description": "API collection for the MyQuery document AI chatbot",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "Documents",
            "item": [
                {
                    "name": "Upload Files",
                    "request": {
                        "method": "POST",
                        "header": [],
                        "url": {
                            "raw": "{{base_url}}/api/v1/admin/documents/upload",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "v1",
                                "admin",
                                "documents",
                                "upload"
                            ]
                        },
                        "description": "Upload one or more documents (PDF, DOC, DOCX, TXT, CSV, XLS, XLSX) for processing."
                    }
                },
                {
                    "name": "Cancel Document Processing",
                    "request": {
                        "method": "POST",
                        "header": [],
                        "url": {
                            "raw": "{{base_url}}/api/v1/admin/documents/cancel/{document_id}",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "v1",
                                "admin",
                                "documents",
                                "cancel",
                                "{document_id}"
                            ]
                        },
                        "description": "Request cooperative cancellation of background processing (e.g. user deleted the document)."
                    }
                },
                {
                    "name": "Restart Document Processing",
                    "request": {
                        "method": "POST",
                        "header": [],
                        "url": {
                            "raw": "{{base_url}}/api/v1/admin/documents/restart-processing/{document_id}",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "v1",
                                "admin",
                                "documents",
                                "restart-processing",
                                "{document_id}"
                            ]
                        },
                        "description": "Restart processing for a document that appears to be stuck."
                    }
                },
                {
                    "name": "Get Document Status",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{base_url}}/api/v1/admin/documents/status/{document_id}",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "v1",
                                "admin",
                                "documents",
                                "status",
                                "{document_id}"
                            ]
                        },
                        "description": "Get processing status for a document."
                    }
                },
                {
                    "name": "Generate Embedding",
                    "request": {
                        "method": "POST",
                        "header": [],
                        "url": {
                            "raw": "{{base_url}}/api/v1/admin/documents/embeddings/generate",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "v1",
                                "admin",
                                "documents",
                                "embeddings",
                                "generate"
                            ]
                        },
                        "description": "Generate embedding for text using the same model as document processing."
                    }
                }
            ]
        }
    ],
    "variable": [
        {
            "key": "base_url",
            "value": "http://localhost:8000",
            "type": "string"
        },
        {
            "key": "auth_token",
            "value": "your_auth_token_here",
            "type": "string",
            "description": "Get this token from the /users endpoint response"
        },
        {
            "key": "userId",
            "value": "your_userId_here",
            "type": "string",
            "description": "Get this ID from the /users endpoint response"
        },
        {
            "key": "session_id",
            "value": "your_session_id_here",
            "type": "string"
        }
    ]
}